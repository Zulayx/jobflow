#!/bin/bash

# JobFlow App Launcher
DIR="$(cd "$(dirname "$0")/.." && pwd)"
cd "$DIR"

# Check if node_modules exists
if [ ! -d "node_modules" ]; then
    osascript -e 'display dialog "First launch: Installing dependencies..." buttons {"OK"} with icon note'
    echo "📦 Installing dependencies..."
    npm install > /dev/null 2>&1
fi

# Check if database exists
if [ ! -f "prisma/dev.db" ]; then
    npx prisma generate > /dev/null 2>&1
    npx prisma db push > /dev/null 2>&1
fi

# Start the dev server in background
osascript -e 'display notification "JobFlow is starting..." with title "JobFlow"'
npm run dev > /dev/null 2>&1 &
DEV_PID=$!

# Wait for server to be ready
echo "Waiting for server to start..."
until curl -s http://localhost:3000 > /dev/null 2>&1; do
    sleep 1
done

# Open in default browser
open http://localhost:3000

# Show notification
osascript -e 'display notification "JobFlow is ready at http://localhost:3000" with title "JobFlow"'

# Wait for dev server
wait $DEV_PID